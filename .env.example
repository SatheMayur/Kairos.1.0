# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./recruitment.db

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hr@yourcompany.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM_NAME=HR Team
EMAIL_FROM_ADDRESS=hr@yourcompany.com

# ── WhatsApp (Twilio) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
TWILIO_SMS_FROM=+1234567890

# ── Job Portals ───────────────────────────────────────────────────────────────
NAUKRI_API_KEY=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
INDEED_PUBLISHER_ID=
FOUNDIT_API_KEY=

# ── Scheduling ────────────────────────────────────────────────────────────────
CALENDAR_BASE_URL=https://your-calendar-service.com
INTERVIEW_CONFIRMATION_BASE_URL=http://localhost:8000

# ── Feature flags ─────────────────────────────────────────────────────────────
USE_MOCK_ADAPTERS=true
AUTO_OUTREACH_ENABLED=true
OUTREACH_DELAY_SECONDS=5
