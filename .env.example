# ─────────────────────────────────────────────────────────────────────────────
#  AI Recruitment System — environment settings
#  Copy this file to ".env" (setup does it for you) and fill in the values.
#  Lines starting with # are notes. Leave optional ones blank if unused.
#  WHERE TO GET SECRETS: easiest is to copy them from your Vercel project
#  (vercel.com → kgirdharlal-recruitment → Settings → Environment Variables),
#  or run:  vercel env pull .env
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development            # 'development' on a PC; 'production' only on the server
SECRET_KEY=change-me
LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────────────────────────────────
# OPTION A — fresh local database on this PC (simplest, starts empty):
DATABASE_URL=sqlite+aiosqlite:///./recruitment.db
# OPTION B — share the SAME live data as the website: paste the Neon URL from
# Vercel (the DATABASE_URL_UNPOOLED value), e.g.
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/neondb?sslmode=require

# ── AI brain (scoring, WhatsApp conversation, message wording, daily plan) ────
AI_PROVIDER=auto               # auto | claude | gemini  (auto prefers Claude when its key is set)
GEMINI_API_KEY=                # from aistudio.google.com  (current live key)
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=             # from console.anthropic.com -> API Keys (starts with sk-ant-)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Candidate sourcing (Apify) ───────────────────────────────────────────────
APIFY_API_TOKEN=               # from apify.com -> Settings -> Integrations
APIFY_APOLLO_ACTOR=coladeu/apollo-people-leads-scraper   # change to a contacts actor for email+phone
APIFY_APOLLO_SEARCH_URL=       # optional: a ready Apollo people-search URL

# ── WhatsApp bridge ──────────────────────────────────────────────────────────
# Shared secret between this app and the Baileys bridge (waha-bridge/). Must match
# the BRIDGE_API_KEY you set when running the bridge.
BRIDGE_API_SECRET=kgirdharlal-bridge-secret

# ── Email sending (Apps Script queue - preferred; no Google key needed) ───────
USE_SHEETS_EMAIL_QUEUE=true
APPS_SCRIPT_WEB_APP_URL=       # the AI_HR_AutoSend web-app /exec URL
APPS_SCRIPT_WEBHOOK_SECRET=    # shared secret set in the Apps Script + here
SHEETS_EMAIL_QUEUE_ID=1u9hSfBLiAZW06x8zVNa_AAYrI-biMKQX2c7rXwiOl5c
EMAIL_FROM_NAME=Kirti | K. Girdharlal International
EMAIL_FROM_ADDRESS=kirti@kgirdharlal.com
# Optional direct SMTP fallback (only if not using the Apps Script queue):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Optional: unattended Gmail/Calendar sync (needs a Google service account) ─
GOOGLE_SA_CREDENTIALS_JSON=    # full service-account JSON string (Workspace admin creates it)

# ── Scheduling / links ───────────────────────────────────────────────────────
INTERVIEW_CONFIRMATION_BASE_URL=http://localhost:8000

# ── Notifications ────────────────────────────────────────────────────────────
DIGEST_ENABLED=true
DIGEST_RECIPIENT_EMAIL=kirti@kgirdharlal.com

# ── Security ─────────────────────────────────────────────────────────────────
CRON_SECRET=                   # protects the /cron/* endpoints (any long random string)

# ── Feature flags (match the live site) ──────────────────────────────────────
USE_MOCK_ADAPTERS=false        # false = real sourcing; true = demo/fake candidates
AUTO_OUTREACH_ENABLED=true
OUTREACH_DELAY_SECONDS=0
IMPORTS_ENABLED=false          # CSV/batch bulk imports stay off (Apna live search still works)
