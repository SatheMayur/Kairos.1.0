{
  "version": 2,
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  },
  "crons": [
    { "path": "/api/v1/cron/source",        "schedule": "30 1 * * *" },
    { "path": "/api/v1/cron/outreach",       "schedule": "0 3 * * *"  },
    { "path": "/api/v1/cron/followup",       "schedule": "30 3 * * *" },
    { "path": "/api/v1/cron/post-interview", "schedule": "0 4 * * *"  },
    { "path": "/api/v1/cron/reminders",      "schedule": "0 2 * * *"  },
    { "path": "/api/v1/cron/digest",         "schedule": "30 2 * * *" },
    { "path": "/api/v1/cron/watchdog",       "schedule": "0 */2 * * *" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/api/index" }
  ],
  "env": {
    "APP_ENV": "production",
    "LOG_LEVEL": "WARNING",
    "USE_MOCK_ADAPTERS": "false",
    "AUTO_OUTREACH_ENABLED": "true",
    "USE_SHEETS_EMAIL_QUEUE": "true",
    "SHEETS_EMAIL_QUEUE_ID": "1u9hSfBLiAZW06x8zVNa_AAYrI-biMKQX2c7rXwiOl5c",
    "SHEETS_MASTER_ID": "1ni68KrCfUmV-5iooy2wI201mfPgKnHOcVzQA2i4XSDI",
    "EMAIL_FROM_NAME": "Kirti | K. Girdharlal International",
    "EMAIL_FROM_ADDRESS": "kirti@kgirdharlal.com",
    "INTERVIEW_CONFIRMATION_BASE_URL": "https://kgirdharlal-recruitment.vercel.app",
    "CLAUDE_MODEL": "claude-sonnet-4-6",
    "DIGEST_ENABLED": "true",
    "DIGEST_RECIPIENT_EMAIL": "kirti@kgirdharlal.com",
    "BRIDGE_API_SECRET": "kgirdharlal-bridge-secret"
  }
}
